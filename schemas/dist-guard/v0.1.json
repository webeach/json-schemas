{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dist-guard Config Schema",
  "description": "Configuration schema for @webeach/dist-guard security scanner",
  "type": "object",
  "properties": {
    "targetDir": {
      "type": "string",
      "description": "Directory to scan for leaked secrets. Resolves relative to the project root.",
      "default": "./dist"
    },
    "pattern": {
      "type": "string",
      "description": "Glob pattern to match files to scan within the target directory.",
      "default": "*.*"
    },
    "ignoreRules": {
      "type": "array",
      "description": "List of rule keys to ignore during the scan.",
      "items": {
        "type": "string",
        "enum": [
          "AirtablePAT",
          "AlgoliaAdminKey",
          "AlibabaCloudAccessKey",
          "AnalyticsSecretKey",
          "AnthropicKey",
          "AWSAccessKey",
          "AWSSecretKey",
          "AzureAppConfigConnectionString",
          "AzureConnectionString",
          "AzureDevOpsPAT",
          "AzureRedisConnectionString",
          "AzureSASToken",
          "BasicAuthURL",
          "BitbucketAppPassword",
          "BraintreeAccessToken",
          "BuildkiteToken",
          "CircleCIToken",
          "ClerkSecretKey",
          "CloudflareAPIToken",
          "CohereAPIKey",
          "ContentfulPAT",
          "DatadogToken",
          "DeepSeekKey",
          "DigitalOceanOAuthToken",
          "DigitalOceanRefreshToken",
          "DigitalOceanToken",
          "DiscordBotToken",
          "DiscordWebhook",
          "DockerAuthConfig",
          "DockerHubToken",
          "DroneCIToken",
          "ElasticEmailKey",
          "ElevenLabsKey",
          "EnvironmentVariable",
          "FigmaToken",
          "FlutterwaveKey",
          "FlyIOToken",
          "FTPCredentials",
          "GCPServiceAccount",
          "GenericAPIKey",
          "GenericConnectionString",
          "GenericSecret",
          "GitHubAppToken",
          "GitHubOAuth",
          "GitHubToken",
          "GitLabPersonalAccessToken",
          "GitLabPipelineToken",
          "GoogleAPIKey",
          "GrafanaToken",
          "GroqKey",
          "HerokuAPIKey",
          "HoneycombAPIKey",
          "HuggingFaceToken",
          "IBMCloudAPIKey",
          "JDBCConnectionString",
          "JWT",
          "LaunchDarklyToken",
          "LinearAPIKey",
          "LineMessagingToken",
          "MailchimpAPIKey",
          "MailgunAPIKey",
          "MailjetAPIKey",
          "MandrillKey",
          "MapboxSecretToken",
          "MicrosoftTeamsWebhook",
          "MongoDBConnectionString",
          "MySQLConnectionString",
          "NetlifyToken",
          "NotionIntegrationToken",
          "NPMTokenV1",
          "NPMTokenV2",
          "NuGetAPIKey",
          "NVIDIANGCKey",
          "OpenAIKey",
          "PaymongoKey",
          "PayPalOAuth",
          "PaystackKey",
          "PGPPrivateKey",
          "PostgreSQLConnectionString",
          "PosthogAPIKey",
          "PostmarkToken",
          "PrivateKey",
          "PulumiAccessToken",
          "PyPIToken",
          "RailwayAPIToken",
          "RedisConnectionString",
          "RenderToken",
          "ReplicateToken",
          "RSAPrivateKey",
          "RubyGemsAPIKey",
          "SanityAPIToken",
          "ScalewayKey",
          "SendGridAPIKey",
          "SentryOrgToken",
          "SentryToken",
          "ShopifyAccessToken",
          "ShopifySharedSecret",
          "SlackBotToken",
          "SlackUserToken",
          "SlackWebhook",
          "SlackWorkspaceToken",
          "SnykKey",
          "SparkPostAPIKey",
          "SQLServerConnectionString",
          "SquareAccessToken",
          "SSHPrivateKey",
          "StripePublishableKey",
          "StripeSecretKey",
          "StripeWebhookSecret",
          "SupabaseToken",
          "TailscaleKey",
          "TelegramBotToken",
          "TerraformCloudToken",
          "TravisCIToken",
          "TwilioAccountSID",
          "TwilioAPIKey",
          "UserHomeDirLeak",
          "VercelToken",
          "VSCEToken",
          "VultrAPIKey",
          "xAIKey"
        ]
      },
      "default": []
    },
    "ignorePatterns": {
      "type": "array",
      "description": "List of glob patterns to ignore (e.g., exclude specific files or directories from being scanned).",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "redact": {
      "type": "boolean",
      "description": "Whether to redact the leaked secrets in the terminal output using asterisks. Highly recommended to keep true so you don't leak secrets into your CI/CD logs.",
      "default": true
    }
  },
  "additionalProperties": false
}
